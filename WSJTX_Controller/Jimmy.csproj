  <!-- Jimmy's Club Log application key lives in a private file outside the
       repo, never an environment variable and never source control. Only the
       path and line number are recorded here (this is a personal machine path,
       not the key itself). -->
  <PropertyGroup>
    <ClubLogKeyFile>C:\Users\Jim\Dropbox\amateur radio\Keys_private\Club Log API key for Jimmy.txt</ClubLogKeyFile>
    <ClubLogKeyLineNumber>9</ClubLogKeyLineNumber>
  </PropertyGroup>

  <!-- Reads a single line out of ClubLogKeyFile without ever logging its
       content. MSBuild has no built-in "read line N of a file" task, so this
       is a small inline task via RoslynCodeTaskFactory. -->
  <UsingTask TaskName="ReadClubLogKeyLine"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <FilePath ParameterType="System.String" Required="true" />
      <LineNumber ParameterType="System.Int32" Required="true" />
      <Key ParameterType="System.String" Output="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        Key = "";
        if (File.Exists(FilePath))
        {
            var lines = File.ReadAllLines(FilePath);
            int idx = LineNumber - 1;
            if (idx >= 0 && idx < lines.Length)
                Key = (lines[idx] ?? "").Trim();
        }
      ]]></Code>
    </Task>
  </UsingTask>

  <!-- Fails ANY build fast (before compiling) if the Club Log key file is
       missing or the expected line is empty. Debug and Release must behave
       identically here (no exceptions), so a Debug build can never silently
       run without real-time/batch Club Log upload working the same way a
       real end-user Release install does. BeforeBuild/AfterBuild are
       recognized extension points that Microsoft.Common.targets already
       calls as part of the Build target, no AfterTargets/BeforeTargets
       wiring needed. -->
  <Target Name="BeforeBuild">
    <Error Condition="!Exists('$(ClubLogKeyFile)')"
           Text="Club Log key file not found: $(ClubLogKeyFile). Set up the key file before building." />
    <ReadClubLogKeyLine Condition="Exists('$(ClubLogKeyFile)')"
                         FilePath="$(ClubLogKeyFile)" LineNumber="$(ClubLogKeyLineNumber)">
      <Output TaskParameter="Key" PropertyName="_ClubLogKey" />
    </ReadClubLogKeyLine>
    <Error Condition="Exists('$(ClubLogKeyFile)') and '$(_ClubLogKey)' == ''"
           Text="Club Log key file exists but line $(ClubLogKeyLineNumber) is empty: $(ClubLogKeyFile). Fix the key file before building." />
  </Target>

  <!-- Embeds Jimmy's Club Log application key into every build's output
       (Debug and Release alike) so real-time/batch upload and country-data
       download work identically regardless of configuration (see
       ClubLogAppKey.cs, resolution option 3). $(_ClubLogKey) was already
       read and validated non-empty by BeforeBuild above; MSBuild properties
       persist across targets within the same build, so it isn't re-read
       here. -->
  <Target Name="AfterBuild">
    <WriteLinesToFile File="$(OutDir)clublog_key.txt" Lines="$(_ClubLogKey)" Overwrite="true" />
  </Target>
