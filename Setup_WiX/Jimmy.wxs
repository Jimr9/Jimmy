<?xml version="1.0" encoding="UTF-8"?>
<!--
  Jimmy installer - WiX 4 source
  Product  : Jimmy (WSJT-X Controller)
  Version  : 1.90.4
  Mfr      : KB0UZT
  Install  : C:\Program Files\KB0UZT\Jimmy\
  Shortcuts: Desktop + Start Menu (optional checkboxes, both on by default)
  Sounds   : installed to Resources\ subfolder
  UpgradeCode retained from original vdproj
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="Jimmy"
    Version="1.90.4"
    Manufacturer="KB0UZT"
    Language="1033"
    Codepage="1252"
    UpgradeCode="{D5415907-DD93-4188-85A8-F15A73F949C2}"
    InstallerVersion="500"
    Compressed="yes">

    <SummaryInformation Description="Jimmy WSJT-X Controller Installer" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Icon for Add/Remove Programs -->
    <Icon Id="JimmyIcon" SourceFile="..\WSJTX_Controller\Properties\netfol.ico" />
    <Property Id="ARPPRODUCTICON" Value="JimmyIcon" />
    <Property Id="ARPCONTACT" Value="KB0UZT" />

    <!-- Standard dialog set: Welcome → InstallDir (Browse) → VerifyReady → Progress → Finish -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <!-- Custom UI fragment that adds ShortcutsDlg and overrides the dialog chain -->
    <UIRef Id="JimmyUI" />

    <!-- Shortcut options: 1 = create (checked), empty = skip (unchecked).
         Both default checked. Secure passes them from UI to elevated execute sequence. -->
    <Property Id="DESKTOP_SHORTCUT" Value="1" Secure="yes" />
    <Property Id="STARTMENU_SHORTCUT" Value="1" Secure="yes" />

    <!-- .NET Framework 4.7.2 check. 461808 is Microsoft's documented minimum
         Release registry value for 4.7.2 (see learn.microsoft.com "How to:
         Determine which .NET Framework versions are installed"). WiX v4's
         RegistrySearch only supports Type="raw" (string); there is no
         integer type, so the numeric comparison is forced in the Launch
         Condition itself via the "#" prefix (standard Windows Installer
         condition syntax for treating a property's string value as a
         number). Without the "#" and a real threshold, a plain existence/
         truthy check would also pass for any older 4.x Full install (4.0
         through 4.6.2), which does not actually satisfy this requirement. -->
    <Property Id="NETFX472RELEASE">
      <RegistrySearch Id="NetFx472Search"
        Root="HKLM"
        Key="SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full"
        Name="Release"
        Type="raw" />
    </Property>
    <Launch Condition="NETFX472RELEASE &gt;=#461808" Message="Jimmy requires .NET Framework 4.7.2 or later.&#xA;&#xA;Download it from: https://dotnet.microsoft.com/en-us/download/dotnet-framework/net472&#xA;&#xA;Install it, then run this installer again." />

    <Feature Id="DefaultFeature" Title="Jimmy" Level="1">
      <ComponentGroupRef Id="MainComponents" />
      <ComponentGroupRef Id="ResourceComponents" />
      <ComponentGroupRef Id="SQLiteInteropComponents" />
      <ComponentGroupRef Id="RuleDefinitionsComponents" />
      <ComponentGroupRef Id="RuleDefinitionsListsComponents" />
      <ComponentRef Id="DesktopShortcutComp" />
      <ComponentRef Id="StartMenuShortcutComp" />
    </Feature>

  </Package>

  <!-- ── Directory structure ────────────────────────────────────────────── -->
  <Fragment>
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="ManufacturerDir" Name="KB0UZT">
        <Directory Id="INSTALLFOLDER" Name="Jimmy">
          <Directory Id="ResourcesDir" Name="Resources" />
          <Directory Id="X86Dir" Name="x86" />
          <Directory Id="X64Dir" Name="x64" />
          <Directory Id="RuleDefinitionsDir" Name="RuleDefinitions">
            <Directory Id="RuleDefinitionsListsDir" Name="Lists" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="ProgramMenuFolder" />
  </Fragment>

  <!-- ── Main install folder ───────────────────────────────────────────── -->
  <Fragment>
    <ComponentGroup Id="MainComponents" Directory="INSTALLFOLDER">

      <Component Id="JimmyExe">
        <File Id="JimmyExeFile"
              Source="..\WSJTX_Controller\bin\Release\Jimmy.exe"
              KeyPath="yes" />
      </Component>

      <Component Id="JimmyConfig">
        <File Id="JimmyConfigFile"
              Source="..\WSJTX_Controller\bin\Release\Jimmy.exe.config" />
      </Component>

      <!-- Jimmy's Club Log application key; see Jimmy.csproj's EmbedClubLogKey
           target (writes this file during Release build) and ClubLogAppKey.cs
           (reads it at runtime). Not a user credential; always present (possibly
           empty) so this component never fails to build. -->
      <Component Id="ClubLogKey">
        <File Id="ClubLogKeyFile"
              Source="..\WSJTX_Controller\bin\Release\clublog_key.txt" />
      </Component>

      <Component Id="AppIcon">
        <File Id="AppIconFile"
              Source="..\WSJTX_Controller\Properties\netfol.ico" />
      </Component>

      <Component Id="SQLiteDll">
        <File Id="SQLiteDllFile"
              Source="..\WSJTX_Controller\bin\Release\System.Data.SQLite.dll"
              KeyPath="yes" />
      </Component>

      <!-- DX Spot Watch (PSKReporter MQTT feed) dependencies, added 2026-07-07.
           MSBuild copies these to bin\Release\ via the project's Reference
           HintPaths; the MSI's file list is manually maintained (no wildcard
           harvesting in this WiX version), so they must be listed explicitly
           here too or a fresh install would be missing them and Jimmy.exe
           would fail to start (DxSpotWatcher is constructed unconditionally
           in Form_Load). -->
      <Component Id="MQTTnetDll">
        <File Id="MQTTnetDllFile"
              Source="..\WSJTX_Controller\bin\Release\MQTTnet.dll"
              KeyPath="yes" />
      </Component>

      <Component Id="MQTTnetManagedClientDll">
        <File Id="MQTTnetManagedClientDllFile"
              Source="..\WSJTX_Controller\bin\Release\MQTTnet.Extensions.ManagedClient.dll"
              KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ── SQLite native interop DLLs (per-architecture) ─────────────────── -->
  <Fragment>
    <ComponentGroup Id="SQLiteInteropComponents">

      <Component Id="SQLiteInteropX86" Directory="X86Dir">
        <File Id="SQLiteInteropX86File"
              Source="..\WSJTX_Controller\bin\Release\x86\SQLite.Interop.dll"
              KeyPath="yes" />
      </Component>

      <Component Id="SQLiteInteropX64" Directory="X64Dir">
        <File Id="SQLiteInteropX64File"
              Source="..\WSJTX_Controller\bin\Release\x64\SQLite.Interop.dll"
              KeyPath="yes" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ── Rule Definitions starter library (Awards engine) ──────────────────
       Seeded by RuleLoader into %LocalAppData%\Jimmy\Data\RuleDefinitions on
       first run. The installed WiX 4.0.6 core schema has no wildcard file
       harvesting (Files Include="glob" is WiX v5+), so each award/list
       file is listed individually; add a new Component/File pair here
       whenever a file is added under RuleDefinitions\. ────────────────────── -->
  <Fragment>
    <ComponentGroup Id="RuleDefinitionsComponents" Directory="RuleDefinitionsDir">

      <Component Id="RuleDef_CQ_DX_Award">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\CQ_DX_Award.ini" />
      </Component>
      <Component Id="RuleDef_Colonies13">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\Colonies13.ini" />
      </Component>
      <Component Id="RuleDef_Colonies13Bonus">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\Colonies13Bonus.ini" />
      </Component>
      <Component Id="RuleDef_DXCC">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\DXCC.ini" />
      </Component>
      <Component Id="RuleDef_IOTA_100Islands">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\IOTA_100Islands.ini" />
      </Component>
      <Component Id="RuleDef_QRZ_DXWorld">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\QRZ_DXWorld.ini" />
      </Component>
      <Component Id="RuleDef_QRZ_GridSquared">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\QRZ_GridSquared.ini" />
      </Component>
      <Component Id="RuleDef_QRZ_USCounties">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\QRZ_USCounties.ini" />
      </Component>
      <Component Id="RuleDef_QRZ_US_Award">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\QRZ_US_Award.ini" />
      </Component>
      <Component Id="RuleDef_QRZ_WorldContinents">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\QRZ_WorldContinents.ini" />
      </Component>
      <Component Id="RuleDef_RAC_Canadaward">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\RAC_Canadaward.ini" />
      </Component>
      <Component Id="RuleDef_RAC_WANA">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\RAC_WANA.ini" />
      </Component>
      <Component Id="RuleDef_Route66OTA">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\Route66OTA.ini" />
      </Component>
      <Component Id="RuleDef_WAC">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAC.ini" />
      </Component>
      <Component Id="RuleDef_WAS">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS.ini" />
      </Component>
      <Component Id="RuleDef_WAS_6M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_6M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_10M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_10M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_12M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_12M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_15M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_15M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_17M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_17M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_20M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_20M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_40M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_40M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_80M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_80M.ini" />
      </Component>
      <Component Id="RuleDef_WAS_160M">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAS_160M.ini" />
      </Component>
      <Component Id="RuleDef_WAZ">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WAZ.ini" />
      </Component>
      <Component Id="RuleDef_WPX">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WPX.ini" />
      </Component>
      <Component Id="RuleDef_WWFF_Hunter">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\WWFF_Hunter.ini" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="RuleDefinitionsListsComponents" Directory="RuleDefinitionsListsDir">

      <Component Id="RuleDefList_Colonies13Roster">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\Lists\colonies13_roster.txt" />
      </Component>
      <Component Id="RuleDefList_Colonies13BonusRoster">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\Lists\colonies13_bonus_roster.txt" />
      </Component>
      <Component Id="RuleDefList_Route66Roster">
        <File Source="..\WSJTX_Controller\bin\Release\RuleDefinitions\Lists\route66_roster.txt" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ── Resources subfolder (WAV files) ───────────────────────────────── -->
  <Fragment>
    <ComponentGroup Id="ResourceComponents" Directory="ResourcesDir">

      <Component Id="BeepBeepWav">
        <File Source="..\WSJTX_Controller\Resources\BeepBeep.wav" />
      </Component>

      <Component Id="BlipWav">
        <File Source="..\WSJTX_Controller\Resources\Blip.wav" />
      </Component>

      <Component Id="ChimeWav">
        <File Source="..\WSJTX_Controller\Resources\Chime.wav" />
      </Component>

      <Component Id="DingDingWav">
        <File Source="..\WSJTX_Controller\Resources\DingDing.wav" />
      </Component>

      <Component Id="DiveWav">
        <File Source="..\WSJTX_Controller\Resources\Dive.wav" />
      </Component>

      <Component Id="EchoWav">
        <File Source="..\WSJTX_Controller\Resources\Echo.wav" />
      </Component>

      <Component Id="TrumpetWav">
        <File Source="..\WSJTX_Controller\Resources\Trumpet.wav" />
      </Component>

    </ComponentGroup>
  </Fragment>

  <!-- ── Shortcuts ──────────────────────────────────────────────────────── -->
  <Fragment>

    <!-- Desktop shortcut: only installed when checkbox is checked.
         Component Condition is evaluated at InstallValidate; empty property = absent. -->
    <Component Id="DesktopShortcutComp" Directory="DesktopFolder" Condition="DESKTOP_SHORTCUT">
      <Shortcut Id="DesktopSC"
                Name="Jimmy"
                Description="WSJT-X Controller"
                Target="[INSTALLFOLDER]Jimmy.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="JimmyIcon"
                IconIndex="0" />
      <RegistryValue Root="HKCU"
                     Key="Software\KB0UZT\Jimmy"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <!-- Start Menu shortcut: only installed when checkbox is checked -->
    <Component Id="StartMenuShortcutComp" Directory="ProgramMenuFolder" Condition="STARTMENU_SHORTCUT">
      <Shortcut Id="StartMenuSC"
                Name="Jimmy"
                Description="WSJT-X Controller"
                Target="[INSTALLFOLDER]Jimmy.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="JimmyIcon"
                IconIndex="0" />
      <RegistryValue Root="HKCU"
                     Key="Software\KB0UZT\Jimmy"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

  </Fragment>

  <!-- ── UI customizations ─────────────────────────────────────────────── -->
  <!--
    WiX 4 merges multiple <UI> fragments into one MSI UI section.
    This fragment adds ShortcutsDlg into the dialog chain after InstallDirDlg.

    Fresh-install flow:
      WelcomeDlg → InstallDirDlg (Browse) → ShortcutsDlg (checkboxes) → VerifyReadyDlg (Install) → ExitDlg (Finish)

    Override strategy:
      - Order=5 on InstallDirDlg Next fires after the built-in Order=4 (→VerifyReadyDlg),
        using the same validity condition so invalid paths still block progression.
      - Order=2 on VerifyReadyDlg Back fires after the built-in Order=1 (→InstallDirDlg),
        redirecting back to ShortcutsDlg instead.
  -->
  <Fragment>
    <UI Id="JimmyUI">
      <!-- Skip LicenseAgreementDlg: WelcomeDlg Next → InstallDirDlg (Order=5 overrides built-in Order=1→LicenseAgreementDlg) -->
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="5"
               Condition="NOT Installed" />

      <!-- Fix InstallDirDlg Back to return to WelcomeDlg (not LicenseAgreementDlg) -->
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="5" />

      <!-- Route: InstallDirDlg Next → ShortcutsDlg -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="ShortcutsDlg" Order="5"
               Condition='WIXUI_DONTVALIDATEPATH OR Installed OR PATCH OR WIXUI_INSTALLDIR_VALID = "1"' />

      <!-- Route: VerifyReadyDlg Back → ShortcutsDlg (fresh install only) -->
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="ShortcutsDlg" Order="2"
               Condition="NOT Installed AND NOT PATCH" />

      <!-- ── ShortcutsDlg ──────────────────────────────────────────── -->
      <Dialog Id="ShortcutsDlg" Width="370" Height="270" Title="[ProductName] Setup">

        <!-- Banner matching WixUI inner-dialog style -->
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

        <!-- Title (bold WixUI font) and subtitle -->
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes" NoPrefix="yes">
          <Text Value="{\WixUI_Font_Title}Shortcuts" />
        </Control>
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes" NoPrefix="yes"
                 Text="Select which shortcuts to create for [ProductName]." />

        <!-- Checkbox: Desktop shortcut -->
        <Control Id="DesktopCheckBox" Type="CheckBox" X="20" Y="90" Width="290" Height="17"
                 Property="DESKTOP_SHORTCUT" CheckBoxValue="1"
                 Text="&amp;Create Desktop shortcut" />

        <!-- Checkbox: Start Menu shortcut -->
        <Control Id="StartMenuCheckBox" Type="CheckBox" X="20" Y="112" Width="290" Height="17"
                 Property="STARTMENU_SHORTCUT" CheckBoxValue="1"
                 Text="Create &amp;Start Menu shortcut" />

        <!-- Bottom separator -->
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <!-- Back: return to InstallDirDlg -->
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
          <Publish Event="NewDialog" Value="InstallDirDlg" />
        </Control>

        <!-- Next: proceed to VerifyReadyDlg (Install button) -->
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" />
        </Control>

        <!-- Cancel: confirm cancellation -->
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>

      </Dialog>
    </UI>
  </Fragment>

</Wix>
